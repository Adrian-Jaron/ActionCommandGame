@using ActionCommandGame.Services.Model.Results
@model IList<PlayerResult>

@{
    ViewData["Title"] = "Leaderboard";
}

<h1>Leaderboard</h1>

@if (Model == null || !Model.Any())
{
    <p>Geen spelers gevonden.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Geld</th>
                <th>Experience</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in Model)
            {
                <tr>
                    <td>@player.Name</td>
                    <td>€@player.Money</td>
                    <td>@player.Experience</td>
                </tr>
            }
        </tbody>
    </table>
}

<a href="/Game/Index">Terug</a>